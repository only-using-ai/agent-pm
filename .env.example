# Optional: use an external Postgres instead of embedded. If unset, the server
# starts an embedded Postgres (no Docker required) in .agent-pm/db.
# DATABASE_URL=postgres://user:password@localhost:5432/agentpm
# Server port (default: 38472, chosen to avoid conflicts with common dev tools)
# PORT=38472

# Frontend: API base URL (defaults to http://localhost:38472)
# VITE_API_URL=http://localhost:38472

# Optional: embedded Postgres (when DATABASE_URL is not set)
# AGENT_PM_EMBEDDED_PG_DATA_DIR=.agent-pm/db
# AGENT_PM_EMBEDDED_PG_PORT=54329
# AGENT_PM_EMBEDDED_PG_VERBOSE=true

# AI providers (for listing models and running agents)
# OLLAMA_URL=http://localhost:11434
# CURSOR_API_KEY=your-cursor-api-key
# CURSOR_BASE_URL=https://api.cursor.com/v1  # If 404, try https://api.cursor.com
# CURSOR_MODEL=claude-4.5-sonnet-thinking     # Use IDs from GET /v0/models
# ANTHROPIC_API_KEY=your-anthropic-api-key
