{
  "name": "agent-pm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"wait-on http://localhost:38472/api/health -t 60000 && vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:frontend": "vite",
    "desktop": "npm run tauri:build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build": "tsc -b && vite build",
    "build:cli": "tsc -p tsconfig.cli.json",
    "pm": "tsx cli/index.ts",
    "daemon": "node deploy/run-daemon-install.js",
    "daemon:user": "node deploy/run-daemon-install.js --user",
    "daemon:restart": "node deploy/run-daemon-restart.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:all": "npm run test:run -- --coverage && cd src-tauri && cargo test"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@langchain/anthropic": "^1.3.22",
    "@langchain/community": "^1.1.22",
    "@langchain/core": "^1.1.31",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.2.12",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tauri-apps/api": "^2.10.1",
    "@uiw/react-md-editor": "^4.0.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "deepagents": "^1.8.1",
    "detect-port": "^1.6.1",
    "dotenv": "^17.3.1",
    "embedded-postgres": "^18.1.0-beta.16",
    "express": "^4.21.0",
    "langchain": "^1.2.30",
    "lucide-react": "^0.577.0",
    "multer": "^2.1.1",
    "pg": "^8.13.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "shadcn": "^4.0.0",
    "streamdown": "^2.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.11.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "concurrently": "^9.0.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.1"
  },
  "bin": {
    "pm": "dist/cli/index.js"
  },
  "overrides": {
    "dotenv": "^17.3.1"
  }
}