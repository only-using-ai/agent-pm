# Agent PM — environment variables
# Copy to .env and set as needed. All variables are optional unless noted.
# See server/config.ts for the canonical source of defaults and env names.

# ─── Server ─────────────────────────────────────────────────────────────────
# Port (default: 38472). Use AGENT_PM_PORT or PORT.
# AGENT_PM_PORT=38472
# PORT=38472

# ─── Database ───────────────────────────────────────────────────────────────
# If set, use this PostgreSQL; otherwise the server starts embedded Postgres in .agent-pm/db.
# DATABASE_URL=postgres://user:password@localhost:5432/agentpm

# Embedded Postgres (only when DATABASE_URL is not set)
# AGENT_PM_EMBEDDED_PG_DATA_DIR=.agent-pm/db
# AGENT_PM_EMBEDDED_PG_PORT=54329
# AGENT_PM_EMBEDDED_PG_VERBOSE=true

# ─── Frontend (Vite) ───────────────────────────────────────────────────────
# API base URL for the web app (default: http://localhost:38472)
# VITE_API_URL=http://localhost:38472

# ─── AI providers ───────────────────────────────────────────────────────────
# Ollama (default base: http://localhost:11434). Use OLLAMA_URL or OLLAMA_BASE_URL.
# OLLAMA_URL=http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# OpenAI (API key required if you use the openai provider)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=   # optional, for custom endpoint
# OPENAI_MODEL=gpt-4o-mini

# Anthropic / Claude (API key required if you use the anthropic provider)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Cursor (for listing models and CLI agent runs)
# CURSOR_API_KEY=your-cursor-api-key
# CURSOR_CLI_PATH=   # optional; default on macOS: /Applications/Cursor.app/Contents/Resources/app/bin/cursor
# CURSOR_MODEL=claude-4.5-sonnet-thinking

# Gemini (CLI only; https://geminicli.com/docs/cli/cli-reference/)
GEMINI_CLI_PATH=/opt/homebrew/bin/gemini   # optional; default: gemini (must be on PATH)
# GEMINI_MODEL=auto  # aliases: auto, pro, flash, flash-lite

# ─── CLI ───────────────────────────────────────────────────────────────────
# API base URL for the pm CLI (default: http://localhost:38472)
# PM_API_URL=http://localhost:38472
# AGENT_PM_API_URL=http://localhost:38472
